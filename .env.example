# The agent harness reads provider credentials from these — set whichever
# matches your model.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Agent harness that drives conversations:
#   pi     - Pi Coding Agent SDK (multi-provider; default)
#   claude - Claude Agent SDK (Anthropic models only; needs ANTHROPIC_API_KEY)
PIPIPE_HARNESS=pi

# Workspace root for file/system tools.
PIPIPE_WORKSPACE=/path/to/your/workspace

# Session map persistence (conversation_key -> pi session file path)
PIPIPE_SESSION_STORE_PATH=/path/to/your/workspace/data/sessions.json

# Optional summary prompt templating for workspace-summary requests
PIPIPE_SUMMARY_PROMPT_ENABLED=true
PIPIPE_SUMMARY_PROMPT_TEMPLATE=Workspace: {{workspace}}\nRequest: {{request}}\nProvide a concise summary with key files and actionable insights.

# Optional transcript logging (off by default)
PIPIPE_TRANSCRIPT_LOG_ENABLED=false
PIPIPE_TRANSCRIPT_LOG_PATH=/path/to/your/workspace/data/transcript.jsonl
PIPIPE_TRANSCRIPT_LOG_MAX_BYTES=1000000
PIPIPE_TRANSCRIPT_LOG_MAX_FILES=3

# Telegram channel
PIPIPE_TELEGRAM_ENABLED=false
PIPIPE_TELEGRAM_TOKEN=
PIPIPE_TELEGRAM_ALLOW_FROM=

# Discord channel
PIPIPE_DISCORD_ENABLED=false
PIPIPE_DISCORD_TOKEN=
PIPIPE_DISCORD_ALLOW_FROM=

# Optional: tuning
PIPIPE_MAX_TOOL_ITERATIONS=20
