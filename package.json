{
  "name": "claude-pipe",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript bot for Telegram and Discord using Claude Code CLI stream-json subprocesses. Inspired by openclaw/openclaw.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.76",
    "discord.js": "^14.24.2",
    "dotenv": "^16.4.5",
    "openai": "^6.21.0",
    "zod": "^4.0.15"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.10.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.57.1",
    "vitest": "^2.1.8"
  }
}
